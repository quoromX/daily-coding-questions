# Copy to .env and replace all change_me values.
APP_NAME=DaoForge
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8080
DATABASE_URL=postgres://daoforge_user:change_me@localhost:5432/daoforge_dev?sslmode=disable
JWT_ACCESS_SECRET=change_me_access_secret_at_least_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_32_chars
PASSWORD_PEPPER=change_me_password_pepper
JUDGE0_BASE_URL=http://localhost:2358
JUDGE0_AUTH_TOKEN=
JUDGE0_WEBHOOK_SECRET=change_me_webhook_secret
CORS_ALLOWED_ORIGINS=http://localhost:3000
PORT=8080
LOG_LEVEL=debug
